generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model ShopSettings {
  id                 String @id @default("singleton")
  shopName           String @default("Sri Lakshmi Jewellery")
  address            String @default("")
  city               String @default("Tiruppur")
  state              String @default("Tamil Nadu")
  pincode            String @default("")
  phone              String @default("")
  email              String @default("")
  gstin              String @default("")
  bankDetails        String @default("")
  logoUrl            String @default("")
  financialYearStart Int    @default(4)
}

model Item {
  id                String          @id @default(cuid())
  itemCode          String          @unique
  itemName          String
  category          Category
  karat             String?
  hsnCode           String          @default("7113")
  makingChargeType  MakingType
  makingChargeValue Decimal         @db.Decimal(10, 2)
  isActive          Boolean         @default(true)
  notes             String?
  createdAt         DateTime        @default(now())
  billItems         SalesBillItem[]
  tags              Tag[]
  purchaseBillItems PurchaseBillItem[]
}

model Supplier {
  id             String   @id @default(cuid())
  supplierCode   String   @unique
  companyName    String
  contactPerson  String?
  phone          String
  address        String   @default("")
  city           String   @default("")
  state          String   @default("")
  gstin          String?
  panNumber      String?
  metalTypes     String[] @default([])
  openingBalance Decimal  @default(0) @db.Decimal(10, 2)
  isActive       Boolean  @default(true)
  notes          String?
  createdBy      String
  createdAt      DateTime @default(now())
  updatedBy      String?
  updatedAt      DateTime @updatedAt
  lots           Lot[]
  purchaseBills  PurchaseBill[]
  purchaseReturns PurchaseReturn[]

  @@index([supplierCode])
}

model Counter {
  id          String    @id @default(cuid())
  counterCode String    @unique
  counterName String
  location    String    @default("")
  metalType   MetalType
  isActive    Boolean   @default(true)
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedBy   String?
  updatedAt   DateTime  @updatedAt
  tags        Tag[]

  @@index([counterCode])
  @@index([metalType])
}

model Lot {
  id            String    @id @default(cuid())
  lotNumber     String    @unique
  supplierId    String?
  supplier      Supplier? @relation(fields: [supplierId], references: [id])
  lotDate       DateTime  @db.Date
  metalType     MetalType
  totalPieces   Int       @default(0)
  totalWeight   Decimal   @default(0) @db.Decimal(10, 3)
  invoiceNumber String?
  purchaseRate  Decimal?  @db.Decimal(10, 2)
  status        LotStatus @default(OPEN)
  notes         String?
  createdBy     String
  createdAt     DateTime  @default(now())
  updatedBy      String?
  updatedAt     DateTime  @updatedAt
  tags          Tag[]
  purchaseBill  PurchaseBill?

  @@index([supplierId])
  @@index([lotDate])
  @@index([status])
}

model Tag {
  id               String          @id @default(cuid())
  tagId            String          @unique
  productId        String
  product          Item            @relation(fields: [productId], references: [id])
  lotId            String?
  lot              Lot?            @relation(fields: [lotId], references: [id])
  counterId        String?
  counter          Counter?        @relation(fields: [counterId], references: [id])
  grossWeight      Decimal         @db.Decimal(10, 3)
  stoneWeight      Decimal         @default(0) @db.Decimal(10, 3)
  netWeight        Decimal         @db.Decimal(10, 3)
  stoneCount       Int             @default(0)
  stoneDescription String?
  huidNumber       String?
  purchaseRate     Decimal?        @db.Decimal(10, 2)
  mrp              Decimal?        @db.Decimal(10, 2)
  status           TagStatus       @default(RECEIVED)
  receivedDate     DateTime        @db.Date
  soldDate         DateTime?       @db.Date
  returnedDate     DateTime?       @db.Date
  notes            String?
  createdBy        String
  createdAt        DateTime        @default(now())
  updatedBy        String?
  updatedAt        DateTime        @updatedAt
  movements        StockMovement[]
  purchaseBillItem PurchaseBillItem?
  purchaseReturnItem PurchaseReturnItem?

  @@index([productId])
  @@index([lotId])
  @@index([counterId])
  @@index([status])
  @@index([receivedDate])
  @@index([huidNumber])
}

model StockMovement {
  id           String            @id @default(cuid())
  tagId        String
  tag          Tag               @relation(fields: [tagId], references: [id])
  movementType StockMovementType
  fromLocation String?
  toLocation   String?
  weight       Decimal           @db.Decimal(10, 3)
  date         DateTime          @db.Date
  referenceId  String?
  createdBy    String
  createdAt    DateTime          @default(now())
  updatedBy    String?
  updatedAt    DateTime          @updatedAt

  @@index([tagId])
  @@index([movementType])
  @@index([date])
}

model PurchaseBill {
  id            String             @id @default(cuid())
  billNumber    String?            @unique
  billDate      DateTime           @db.Date
  supplierId    String
  supplier      Supplier           @relation(fields: [supplierId], references: [id])
  invoiceNumber String?
  metalType     MetalType
  lotId         String?            @unique
  lot           Lot?               @relation(fields: [lotId], references: [id])
  totalPieces   Int                @default(0)
  totalWeight   Decimal            @default(0) @db.Decimal(10, 3)
  totalAmount   Decimal            @default(0) @db.Decimal(10, 2)
  paymentMode   PaymentMode        @default(CASH)
  status        BillStatus         @default(DRAFT)
  notes         String?
  createdBy     String
  createdAt     DateTime           @default(now())
  updatedBy     String?
  updatedAt     DateTime           @updatedAt
  items         PurchaseBillItem[]
  returns       PurchaseReturn[]

  @@index([supplierId])
  @@index([billDate])
  @@index([status])
}

model PurchaseBillItem {
  id           String       @id @default(cuid())
  billId       String
  bill         PurchaseBill @relation(fields: [billId], references: [id], onDelete: Cascade)
  tagId        String?      @unique
  tag          Tag?         @relation(fields: [tagId], references: [id])
  productId    String
  product      Item         @relation(fields: [productId], references: [id])
  grossWeight  Decimal      @db.Decimal(10, 3)
  stoneWeight  Decimal      @default(0) @db.Decimal(10, 3)
  netWeight    Decimal      @db.Decimal(10, 3)
  huidNumber   String?
  purchaseRate Decimal      @db.Decimal(10, 2)
  amount       Decimal      @db.Decimal(10, 2)
  sortOrder    Int          @default(0)

  @@index([billId])
  @@index([productId])
}

model OldMetalPurchase {
  id              String      @id @default(cuid())
  voucherNumber   String?     @unique
  voucherDate     DateTime    @db.Date
  customerId      String?
  customer        Customer?   @relation(fields: [customerId], references: [id])
  customerName    String?
  metalType       MetalType
  karat           String?
  itemDescription String
  grossWeight     Decimal     @db.Decimal(10, 3)
  stoneWeight     Decimal     @default(0) @db.Decimal(10, 3)
  netWeight       Decimal     @db.Decimal(10, 3)
  purity          Decimal     @db.Decimal(5, 2)
  ratePerGram     Decimal     @db.Decimal(10, 2)
  totalAmount     Decimal     @db.Decimal(10, 2)
  paymentMode     PaymentMode @default(CASH)
  notes           String?
  createdBy       String
  createdAt       DateTime    @default(now())
  updatedBy       String?
  updatedAt       DateTime    @updatedAt

  @@index([voucherDate])
  @@index([customerId])
  @@index([metalType])
}

model PurchaseReturn {
  id             String               @id @default(cuid())
  returnNumber   String?              @unique
  originalBillId String
  originalBill   PurchaseBill         @relation(fields: [originalBillId], references: [id])
  returnDate     DateTime             @db.Date
  supplierId     String
  supplier       Supplier             @relation(fields: [supplierId], references: [id])
  reason         String
  status         BillStatus           @default(DRAFT)
  notes          String?
  createdBy      String
  createdAt      DateTime             @default(now())
  updatedBy      String?
  updatedAt      DateTime             @updatedAt
  items          PurchaseReturnItem[]

  @@index([originalBillId])
  @@index([supplierId])
  @@index([returnDate])
  @@index([status])
}

model PurchaseReturnItem {
  id       String         @id @default(cuid())
  returnId String
  return   PurchaseReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
  tagId    String         @unique
  tag      Tag            @relation(fields: [tagId], references: [id])

  @@index([returnId])
}

model Customer {
  id             String       @id @default(cuid())
  customerCode   String       @unique
  name           String
  phone          String       @unique
  phoneAlt       String?
  address        String       @default("")
  city           String       @default("Tiruppur")
  state          String       @default("Tamil Nadu")
  pincode        String       @default("")
  gstin          String?
  panNumber      String?
  aadharNumber   String?
  customerType   CustomerType @default(RETAIL)
  creditLimit    Decimal      @default(0) @db.Decimal(10, 2)
  openingBalance Decimal      @default(0) @db.Decimal(10, 2)
  isActive       Boolean      @default(true)
  notes          String?
  dateJoined     DateTime     @default(now())
  bills          SalesBill[]
  oldMetalPurchases OldMetalPurchase[]
  chitMembers    ChitMember[]
}

model DailyRate {
  id          String   @id @default(cuid())
  date        DateTime @unique @db.Date
  gold24kRate Decimal  @db.Decimal(10, 2)
  gold22kRate Decimal  @db.Decimal(10, 2)
  gold18kRate Decimal  @db.Decimal(10, 2)
  silverRate  Decimal  @db.Decimal(10, 2)
  enteredBy   String
  createdAt   DateTime @default(now())
  notes       String?
}

model SalesBill {
  id             String          @id @default(cuid())
  billNumber     String?         @unique
  billDate       DateTime        @db.Date
  billType       BillType        @default(CASH)
  customerId     String?
  customer       Customer?       @relation(fields: [customerId], references: [id])
  walkInName     String?
  subtotal       Decimal         @db.Decimal(10, 2)
  cgstAmount     Decimal         @default(0) @db.Decimal(10, 2)
  sgstAmount     Decimal         @default(0) @db.Decimal(10, 2)
  igstAmount     Decimal         @default(0) @db.Decimal(10, 2)
  discountAmount Decimal         @default(0) @db.Decimal(10, 2)
  roundOff       Decimal         @default(0) @db.Decimal(5, 2)
  totalAmount    Decimal         @db.Decimal(10, 2)
  amountPaid     Decimal         @db.Decimal(10, 2)
  balanceDue     Decimal         @db.Decimal(10, 2)
  paymentMode    PaymentMode     @default(CASH)
  status         BillStatus      @default(DRAFT)
  createdBy      String
  createdAt      DateTime        @default(now())
  notes          String?
  items          SalesBillItem[]
}

model SalesBillItem {
  id                 String     @id @default(cuid())
  billId             String
  bill               SalesBill  @relation(fields: [billId], references: [id], onDelete: Cascade)
  itemId             String
  item               Item       @relation(fields: [itemId], references: [id])
  tagNumber          String?
  description        String
  grossWeight        Decimal    @db.Decimal(10, 3)
  stoneWeight        Decimal    @default(0) @db.Decimal(10, 3)
  netWeight          Decimal    @db.Decimal(10, 3)
  wastagePercent     Decimal    @default(0) @db.Decimal(5, 2)
  wastageWeight      Decimal    @default(0) @db.Decimal(10, 3)
  totalWeight        Decimal    @db.Decimal(10, 3)
  ratePerGram        Decimal    @db.Decimal(10, 2)
  goldValue          Decimal    @db.Decimal(10, 2)
  makingChargeType   MakingType
  makingChargeValue  Decimal    @db.Decimal(10, 2)
  makingChargeAmount Decimal    @db.Decimal(10, 2)
  stoneCharge        Decimal    @default(0) @db.Decimal(10, 2)
  taxableAmount      Decimal    @db.Decimal(10, 2)
  gstRate            Decimal    @default(3.0) @db.Decimal(5, 2)
  gstAmount          Decimal    @db.Decimal(10, 2)
  lineTotal          Decimal    @db.Decimal(10, 2)
  sortOrder          Int        @default(0)
}

model LedgerAccount {
  id             String        @id @default(cuid())
  accountCode    String        @unique
  accountName    String
  accountGroup   AccountGroup
  openingBalance Decimal       @default(0) @db.Decimal(12, 2)
  isActive       Boolean       @default(true)
  createdBy      String
  createdAt      DateTime      @default(now())
  updatedBy      String?
  updatedAt      DateTime      @updatedAt
  journalLines   JournalEntryLine[]
  bankAccounts   BankAccount[]

  @@index([accountGroup])
  @@index([accountCode])
}

model JournalEntry {
  id           String             @id @default(cuid())
  entryNumber  String             @unique
  entryDate    DateTime           @db.Date
  description  String
  createdBy    String
  createdAt    DateTime           @default(now())
  updatedBy    String?
  updatedAt    DateTime           @updatedAt
  lines        JournalEntryLine[]
  voucher      Voucher?

  @@index([entryDate])
}

model JournalEntryLine {
  id            String         @id @default(cuid())
  journalId     String
  journal       JournalEntry   @relation(fields: [journalId], references: [id], onDelete: Cascade)
  accountId     String
  account       LedgerAccount  @relation(fields: [accountId], references: [id])
  debitAmount   Decimal        @default(0) @db.Decimal(12, 2)
  creditAmount  Decimal        @default(0) @db.Decimal(12, 2)
  narration     String?
  referenceType ReferenceType?
  referenceId   String?

  @@index([journalId])
  @@index([accountId])
  @@index([referenceType, referenceId])
}

model BankAccount {
  id             String            @id @default(cuid())
  bankName       String
  accountNumber  String
  branch         String            @default("")
  ifsc           String            @default("")
  openingBalance Decimal           @default(0) @db.Decimal(12, 2)
  ledgerAccountId String?
  ledgerAccount  LedgerAccount?    @relation(fields: [ledgerAccountId], references: [id])
  isActive       Boolean           @default(true)
  createdBy      String
  createdAt      DateTime          @default(now())
  updatedBy      String?
  updatedAt      DateTime          @updatedAt
  transactions   BankTransaction[]

  @@index([bankName])
}

model BankTransaction {
  id            String         @id @default(cuid())
  bankAccountId String
  bankAccount   BankAccount    @relation(fields: [bankAccountId], references: [id])
  date          DateTime       @db.Date
  description   String
  debit         Decimal        @default(0) @db.Decimal(12, 2)
  credit        Decimal        @default(0) @db.Decimal(12, 2)
  balance       Decimal        @default(0) @db.Decimal(12, 2)
  referenceType ReferenceType?
  referenceId   String?
  isCleared     Boolean        @default(false)
  clearedDate   DateTime?      @db.Date
  createdBy     String
  createdAt     DateTime       @default(now())
  updatedBy     String?
  updatedAt     DateTime       @updatedAt

  @@index([bankAccountId])
  @@index([date])
  @@index([isCleared])
}

model Voucher {
  id              String       @id @default(cuid())
  voucherNumber   String       @unique
  date            DateTime     @db.Date
  type            VoucherType
  partyName       String       @default("")
  amount          Decimal      @db.Decimal(12, 2)
  paymentMode     PaymentMode  @default(CASH)
  narration       String?
  journalEntryId  String?      @unique
  journalEntry    JournalEntry? @relation(fields: [journalEntryId], references: [id])
  createdBy       String
  createdAt       DateTime     @default(now())
  updatedBy       String?
  updatedAt       DateTime     @updatedAt

  @@index([date])
  @@index([type])
}

model DayEnd {
  id                 String   @id @default(cuid())
  date               DateTime @unique @db.Date
  openingCash        Decimal  @db.Decimal(12, 2)
  totalSales         Decimal  @db.Decimal(12, 2)
  totalPurchases     Decimal  @db.Decimal(12, 2)
  totalChitCollection Decimal @default(0) @db.Decimal(12, 2)
  totalExpenses      Decimal  @default(0) @db.Decimal(12, 2)
  closingCash        Decimal  @db.Decimal(12, 2)
  isDayLocked        Boolean  @default(true)
  lockedBy           String
  lockedAt           DateTime @default(now())
  dayEndReport       Json?
  createdBy          String
  createdAt          DateTime @default(now())
  updatedBy          String?
  updatedAt          DateTime @updatedAt

  @@index([date])
}

model ChitScheme {
  id               String           @id @default(cuid())
  schemeCode       String           @unique
  schemeName       String
  durationMonths   Int
  instalmentAmount Decimal          @db.Decimal(10, 2)
  totalMembers     Int              @default(0)
  startDate        DateTime         @db.Date
  maturityDate     DateTime         @db.Date
  bonusMonth       Int?
  status           ChitSchemeStatus @default(ACTIVE)
  notes            String?
  createdBy        String
  createdAt        DateTime         @default(now())
  updatedBy        String?
  updatedAt        DateTime         @updatedAt
  members          ChitMember[]
  payments         ChitPayment[]

  @@index([status])
  @@index([startDate])
}

model ChitMember {
  id             String           @id @default(cuid())
  memberId       String           @unique
  schemeId       String
  scheme         ChitScheme       @relation(fields: [schemeId], references: [id])
  customerId     String
  customer       Customer         @relation(fields: [customerId], references: [id])
  enrolmentDate  DateTime         @db.Date
  totalAmount    Decimal          @db.Decimal(10, 2)
  status         ChitMemberStatus @default(ACTIVE)
  notes          String?
  createdBy      String
  createdAt      DateTime         @default(now())
  updatedBy      String?
  updatedAt      DateTime         @updatedAt
  payments       ChitPayment[]

  @@index([schemeId])
  @@index([customerId])
  @@index([status])
}

model ChitPayment {
  id                String      @id @default(cuid())
  memberId          String
  member            ChitMember  @relation(fields: [memberId], references: [id])
  schemeId          String
  scheme            ChitScheme  @relation(fields: [schemeId], references: [id])
  paymentDate       DateTime    @db.Date
  instalmentNumber  Int
  amount            Decimal     @db.Decimal(10, 2)
  paymentMode       PaymentMode @default(CASH)
  collectedBy       String
  receiptNumber     String      @unique
  notes             String?
  createdBy         String
  createdAt         DateTime    @default(now())
  updatedBy         String?
  updatedAt         DateTime    @updatedAt

  @@index([memberId])
  @@index([schemeId])
  @@index([paymentDate])
  @@index([instalmentNumber])
}

enum Category {
  GOLD
  SILVER
  DIAMOND
  STONE
  OTHER
}

enum MakingType {
  PER_GRAM
  PERCENTAGE
  FIXED
}

enum CustomerType {
  RETAIL
  WHOLESALE
  VIP
}

enum BillType {
  CASH
  CREDIT
  EXCHANGE
}

enum PaymentMode {
  CASH
  CARD
  UPI
  CHEQUE
  MULTIPLE
}

enum BillStatus {
  DRAFT
  CONFIRMED
  CANCELLED
}

enum MetalType {
  GOLD
  SILVER
  DIAMOND
}

enum TagStatus {
  RECEIVED
  COUNTER_ASSIGNED
  SOLD
  RETURNED
  WITH_KARIGAR
}

enum LotStatus {
  OPEN
  CLOSED
}

enum StockMovementType {
  PURCHASE_IN
  SALE_OUT
  RETURN_IN
  KARIGAR_OUT
  KARIGAR_IN
  COUNTER_TRANSFER
}

enum AccountGroup {
  ASSET
  LIABILITY
  INCOME
  EXPENSE
  EQUITY
}

enum ReferenceType {
  BILL
  PURCHASE
  PAYMENT
  RECEIPT
  JOURNAL
  VOUCHER
  OLD_METAL
  DAY_END
}

enum VoucherType {
  RECEIPT
  PAYMENT
  JOURNAL
  ISSUE
}

enum ChitSchemeStatus {
  ACTIVE
  CLOSED
}

enum ChitMemberStatus {
  ACTIVE
  CLOSED
  DEFAULTED
}
